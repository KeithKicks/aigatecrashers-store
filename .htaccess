# AI Gatecrashers — Apache security rules

# Block access to archive/zip files
<FilesMatch "\.(tar\.gz|tgz|zip|tar|gz|bz2|rar|7z)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Block .md files everywhere except under /blog/
<FilesMatch "\.md$">
  Order allow,deny
  Deny from all
</FilesMatch>
<Directory "/blog">
  <FilesMatch "\.md$">
    Order allow,deny
    Allow from all
  </FilesMatch>
</Directory>

# Block access to protected asset directories
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Block assets/email-sequences/
  RewriteRule ^assets/email-sequences(/.*)?$ - [F,L]

  # Block assets/prompt-packs/
  RewriteRule ^assets/prompt-packs(/.*)?$ - [F,L]

  # Block assets/prompt-pack-deliverables/
  RewriteRule ^assets/prompt-pack-deliverables(/.*)?$ - [F,L]
</IfModule>

# Deny direct access to hidden files
<FilesMatch "^\.">
  Order allow,deny
  Deny from all
</FilesMatch>

# Pretty URLs: /product/?id=slug works via directory index
DirectoryIndex index.html index.htm

# Enable compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType application/json "access plus 1 hour"
</IfModule>
